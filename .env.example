# ============================================
# PRISM ONE — Variáveis de Ambiente
# ============================================

# Banco de dados (MariaDB/MySQL)
DATABASE_URL=mysql://usuario:senha@host:3306/nome_do_banco
DB_HOST=localhost
DB_PORT=3306
DB_NAME=prism_one
DB_USER=prism
DB_PASS=sua_senha_aqui

# Autenticação (NextAuth v5)
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET=TROCAR-gerar-com-openssl-rand-base64-32
NEXTAUTH_URL=https://prismone.seudominio.com.br
AUTH_SECRET=TROCAR-mesmo-valor-do-nextauth-secret

# Ambiente
NODE_ENV=production
